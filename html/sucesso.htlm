<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agendamento Confirmado - PetCare</title>
    <link rel="stylesheet" href="../css/style.css">
    <link rel="stylesheet" href="../css/sucesso.css">
    <link rel="icon" href="../img/favicon.png" type="image/png">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>

    <header class="navbar">
        <div class="logo">
            <img src="../img/logo.jpg" alt="Logo">
            <h1>PetCare</h1>
        </div>
        <nav>
            <a href="#">Perfil</a>
            <a href="#">Agendamento</a>
            <a href="#">Exames</a>
            <a href="#">Configurações</a>
        </nav>
    </header>

    <section class="banner">
        <h2>Agende consultas e exames para seu pet</h2>
        <p>Cuidado rápido, fácil e organizado</p>
    </section>

    <section class="feedback-section">
        <div class="feedback-card">
            <div class="feedback-icon">✅</div>
            <h2>Agendamento Confirmado!</h2>
            <p>Seu agendamento foi realizado com sucesso.<br>Até logo! 🐾</p>
            <a href="../html/index.html" class="btn-voltar">Fazer novo agendamento</a>
        </div>
    </section>

    <section class="cards">
        <div class="card">
            <h3 class="text">Agendamentos</h3>
            <p>Gerencie consultas</p>
        </div>
        <div class="card">
            <h3 class="text">Exames</h3>
            <p>Acompanhe resultados</p>
        </div>
        <div class="card">
            <h3 class="text">Configurações</h3>
            <p>Ajuste sua conta</p>
        </div>
    </section>

</body>
</html>